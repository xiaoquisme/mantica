# Database
POSTGRES_DB=mantica
POSTGRES_USER=mantica
POSTGRES_PASSWORD=multica
POSTGRES_PORT=5432
DATABASE_URL=postgres://mantica:password@localhost:5432/mantica?sslmode=disable

# Server
PORT=8080
JWT_SECRET=change-me-in-production
MANTICA_SERVER_URL=ws://localhost:8080/ws
MANTICA_APP_URL=http://localhost:3000
MANTICA_DAEMON_CONFIG=
MANTICA_WORKSPACE_ID=
MANTICA_DAEMON_ID=
MANTICA_DAEMON_DEVICE_NAME=
MANTICA_DAEMON_POLL_INTERVAL=3s
MANTICA_DAEMON_HEARTBEAT_INTERVAL=15s
MANTICA_CODEX_PATH=codex
MANTICA_CODEX_MODEL=
MANTICA_CODEX_WORKDIR=
MANTICA_CODEX_TIMEOUT=20m

# Agent seed config (path to agent_config.yaml, default: agent_config.yaml relative to server cwd)
MANTICA_AGENT_CONFIG=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@mantica.ai

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# S3 / CloudFront
S3_BUCKET=
S3_REGION=us-west-2
# Optional: custom endpoint for MinIO or other S3-compatible self-hosted storage.
# When set, AWS credentials are used as MinIO access/secret key — no real AWS account needed.
S3_ENDPOINT=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=multica/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=

# Frontend
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Remote API (optional) — set to proxy local frontend to a remote backend
# Leave empty to use local backend (localhost:8080)
# REMOTE_API_URL=https://mantica-api.copilothub.ai
